---
import ContentSubHeader from "./ContentSubHeader.astro";
import ContentHeader from "./ContentHeader.astro";
import { CONTACT, COMPANY_DATA } from "../content/contact";
import ContentDescription from "./ContentDescription.astro";
import Form from "./Form.astro";
---

<section id={CONTACT.id} class="bg-radial-dark scroll-mt-15 md:scroll-mt-22.5">
    <div
        data-aos="fade-up"
        class="max-w-7xl items-center justify-center m-auto py-10 md:py-30 px-5"
    >
        <div
            class="grid grid-cols-1 gap-4 lg:grid-cols-2 lg:gap-18 items-center justify-center m-auto"
        >
            <div>
                <ContentHeader
                    text={CONTACT.header}
                    class="text-secondary text-left"
                />
                <ContentSubHeader
                    text={CONTACT.subHeader}
                    class="gradient-light text-left mx-0"
                />

                <ContentDescription
                    text={CONTACT.description}
                    class="text-secondary"
                />
                <div class="mt-5">
                    <Form />
                </div>
            </div>
            <div class="flex flex-col gap-2">
                <div
                    class="flex flex-col min-[445px]:flex-row flex-wrap gap-2 justify-center text-secondary"
                >
                    {
                        CONTACT.contactData.map((i) => {
                            const Icon = i.icon;

                            const href =
                                i.type === "email"
                                    ? `mailto:${i.contact}`
                                    : `tel:${i.contact.replace(/\s+/g, "")}`;

                            return (
                                <div
                                    
                                    class="flex-1 flex flex-col gap-2 p-2 md:p-5 border-2 border-transparent rounded-lg hover:border-2 hover:border-secondary/40 transition-all duration-500 group"
                                >
                                    <Icon class="w-8 h-8 transition-colors duration-500 group-hover:text-accent" />
                                    <h4 class="text-xl md:text-3xl font-semibold">
                                        {i.head}
                                    </h4>
                                    <p>{i.text}</p>
                                    <a  href={href}
                                        class="w-fit transition-colors duration-500 group-hover:text-accent select-text">{i.contact}
                                    </a>
                                </div>
                            );
                        })
                    }
                </div>
                <div class="flex-1 flex flex-col text-secondary gap-2 p-2 md:p-5 border-2 border-transparent rounded-lg hover:border-2 hover:border-secondary/40 transition-all duration-500 group">
                    {
                        COMPANY_DATA.map((i) => {
                            const Icon = i.icon;

                            return (
                                <Icon class="w-8 h-8 transition-colors duration-500 group-hover:text-accent" />
                                <h4 class="text-xl md:text-3xl font-semibold">
                                    {i.head}
                                </h4>
                                <h5 class="text-lg md:text-xl font-semibold transition-colors duration-500 group-hover:text-accent">{i.name}</h5>
                                <p>{i.street}</p>
                                <p>{i.city}</p>
                                <p class="transition-colors duration-500 group-hover:text-accent">{i.nip}</p>
                            )
                        })
                    }
                </div>
            </div>
        </div>
    </div>
</section>
