<form
    action="https://formspree.io/f/mwvnbpwl"
    method="POST"
    class="space-y-4 text-secondary"
>
    <label for="name">Nazwa firmy / Imię</label>
    <input
        id="name"
        type="text"
        name="Nazwa firmy / Imię"
        placeholder="np. Krzysiek"
        autocomplete="name"
        required
        class="w-full p-3 rounded-lg border-2 border-secondary/40 focus:outline-secondary/50"
    />
    <label for="email">Email</label>
    <input
        id="email"
        type="email"
        name="Email"
        placeholder="Twój email"
        autocomplete="email"
        required
        class="w-full p-3 rounded-lg border-2 border-secondary/40 focus:outline-secondary/50"
    />
    <label for="message">Wiadomość</label>
    <textarea
        id="message"
        rows="6"
        name="Wiadomość"
        placeholder="Opowiedz nam o swoim projekcie"
        required
        class="w-full p-3 m-0 rounded-lg border-2 border-secondary/40 focus:outline-secondary/50"
    ></textarea>
    <p class="mt-2">
        Wysyłając formularz, wyrażasz zgodę na przetwarzanie podanych danych w
        celu kontaktu i obsługi zapytania, zgodnie z
        <a
            href="/polityka-prywatnosci/"
            class="underline hover:text-accent transition-colors duration-500 ease"
        >
            Polityką prywatności
        </a>.
    </p>
    <div
        data-form-message
        class="mt-4 text-accent font-semibold opacity-0 transition-opacity duration-500"
    >
    </div>
    <button
        type="submit"
        class="px-5 py-2.5 my-4 text-lg md:text-xl rounded-lg text-center cursor-pointer self-start transition-colors duration-500 ease border-2 inline-block bg-accent border-accent text-secondary hover:bg-accent-hover hover:border-accent-hover"
    >
        Wyślij
    </button>
</form>

<script>
    import { initContactForms } from "../scripts/form";

    initContactForms();
    document.addEventListener("astro:page-load", initContactForms);
</script>
